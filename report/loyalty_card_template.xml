<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_loyalty_card">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif;">

                        <!-- Título del Reporte -->
                        <div style="text-align: center; margin-top: 40px; margin-bottom: 30px;">
                            <h1 style="color: #875A7B; font-size: 36px; margin-bottom: 5px;">
                                <strong>FICHA DE FIDELIDAD</strong>
                            </h1>
                            <p style="font-size: 16px; color: #888; margin: 0;">Programa de Lealtad del Cliente</p>
                        </div>
                        <hr style="border-top: 3px solid #875A7B; margin-bottom: 40px;"/>

                        <!-- Datos del Cliente -->
                        <div style="margin-bottom: 40px;">
                            <h3 style="color: #875A7B; margin-bottom: 20px; font-size: 22px;">
                                <strong>Datos del Cliente</strong>
                            </h3>
                            <table style="width: 100%; border-collapse: collapse; font-size: 16px;">
                                <tr>
                                    <td style="width: 30%; padding: 14px 16px; background-color: #f2f2f2; border: 1px solid #ddd; font-weight: bold; font-size: 16px;">
                                        Nombre
                                    </td>
                                    <td style="padding: 14px 16px; border: 1px solid #ddd; font-size: 16px;">
                                        <span t-field="doc.name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 14px 16px; background-color: #f2f2f2; border: 1px solid #ddd; font-weight: bold; font-size: 16px;">
                                        Correo Electrónico
                                    </td>
                                    <td style="padding: 14px 16px; border: 1px solid #ddd; font-size: 16px;">
                                        <span t-field="doc.email"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 14px 16px; background-color: #f2f2f2; border: 1px solid #ddd; font-weight: bold; font-size: 16px;">
                                        Teléfono
                                    </td>
                                    <td style="padding: 14px 16px; border: 1px solid #ddd; font-size: 16px;">
                                        <span t-field="doc.phone"/>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Información de Fidelidad -->
                        <div style="margin-bottom: 40px;">
                            <h3 style="color: #875A7B; margin-bottom: 20px; font-size: 22px;">
                                <strong>Información de Fidelidad</strong>
                            </h3>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr>
                                        <th style="width: 50%; background-color: #875A7B; color: white; padding: 16px; text-align: center; font-size: 18px; border: 1px solid #875A7B;">
                                            Nivel de Fidelidad
                                        </th>
                                        <th style="width: 50%; background-color: #875A7B; color: white; padding: 16px; text-align: center; font-size: 18px; border: 1px solid #875A7B;">
                                            Puntos Acumulados
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td style="text-align: center; padding: 30px; border: 1px solid #ddd; background-color: #f8f4fa;">
                                            <span style="font-size: 32px; color: #875A7B; font-weight: bold;">
                                                <t t-esc="dict([('bronze','BRONCE'),('silver','PLATA'),('gold','ORO'),('platinum','PLATINO')]).get(doc.loyalty_level, '')"/>
                                            </span>
                                        </td>
                                        <td style="text-align: center; padding: 30px; border: 1px solid #ddd; background-color: #f8f4fa;">
                                            <span style="font-size: 32px; color: #875A7B; font-weight: bold;">
                                                <t t-esc="doc.loyalty_points"/>
                                            </span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Observaciones -->
                        <div style="margin-top: 50px; padding: 20px; background-color: #f9f9f9; border: 1px solid #eee; border-radius: 4px;">
                            <p style="font-size: 14px; color: #666; margin: 0; text-align: center;">
                                Este documento certifica el estado de fidelidad del cliente
                                <strong><span t-field="doc.name"/></strong>
                                en el programa de lealtad de
                                <strong><t t-esc="doc.company_id.name or 'la empresa'"/></strong>.
                            </p>
                        </div>

                        <!-- Firma -->
                        <table style="width: 100%; margin-top: 80px;">
                            <tr>
                                <td style="width: 50%; text-align: center;">
                                    <div style="border-top: 1px solid #333; width: 200px; margin: 0 auto; padding-top: 8px;">
                                        <span style="font-size: 13px; color: #555;">Firma del Responsable</span>
                                    </div>
                                </td>
                                <td style="width: 50%; text-align: center;">
                                    <div style="border-top: 1px solid #333; width: 200px; margin: 0 auto; padding-top: 8px;">
                                        <span style="font-size: 13px; color: #555;">Sello de la Empresa</span>
                                    </div>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
